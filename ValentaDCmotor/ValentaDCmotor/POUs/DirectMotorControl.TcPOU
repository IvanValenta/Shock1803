<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.17">
  <POU Name="DirectMotorControl" Id="{17dd0409-38d0-4132-ac94-8e137c00e896}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM DirectMotorControl
VAR
	bHMI_RESET: BOOL;	// reset gresaka
 
	bMotorOn: BOOL;
	rVelocitySetpoint: LREAL;
	rPotFeedback_V: REAL;
	rPotFeedback_Radno_Perc: LREAL;
	rRadno_Min_Pos: LREAL;	// Radni limit 0%
	rRadno_Max_Pos: REAL;	// Radni limit 100%
	
   // Realni Potenciometar - u RAW vrijednosti
    cPotMin: REAL := 0.55;             // kΩ ili V
    cPotMax: REAL := 7.16;             // kΩ ili V
	rLinearPosition: LREAL;	// realna pozicija max hoda od 81mm

	rLinearPosition_LimMin: LREAL;	// Limit iskljucenja
	rLinearPosition_LimMAx: LREAL;	// Limit iskljucenja
	
	// Parametri regulacije (NOVO)
    rSetpoint: REAL := 50.0;      // Željena pozicija 0-100%
    rMinVelocity: REAL := 10.0;     // Min brzina za start %
    rMaxVelocity: REAL := 100.0;   // Max brzina %
    rDeadband: REAL := 1.0;        // Deadband ±1%
    rKp: REAL := 10;              // P pojačanje
    
    // Procesne varijable (NOVO)
    rError: REAL;	// greska slijeđenja
    rVelocityCmd: REAL;
    bInDeadband: BOOL;	// Unutar pozicije
	
   // NOVO - Rampa varijable
    rSetpointTarget: REAL := 50.0;    // Ciljna pozicija
    rRampRate: REAL := 50.0;          // Brzina rampe [%/s]
	
   // NOVO - Računanje brzine
    rActualVelocity: REAL;        // Stvarna brzina [%/s]
    rActualVelocityRPM: REAL;     // Stvarna brzina [RPM]
    rLastPosition: LREAL;          // Prethodna pozicija
    rDeltaPosition: LREAL;         // Promjena pozicije
    fbVelocityTimer: TON;         // Timer za uzorkovanje
    tSampleTime: TIME := T#50MS;  // Vrijeme uzorkovanja
    
    // Filter za brzinu (opciono)
    rVelocityFiltered: REAL;
    rFilterConst: REAL := 0.3;    // Filter konstanta (0.1-0.5)

	rMotorVoltage: LREAL;
	rMotorCurrent: LREAL;
	Tgen1: TON;
	bTick: BOOL;
	TP1: TP;
	bTakt: BOOL;
	rSetpointTarget_Min: REAL:=0.0;
	rSetpointTarget_Max: REAL:=100.0;
	
	bSetVelOverPoz: BOOL;
	bSetVelOverNeg: BOOL;
	
	R_Tgen1: R_TRIG;

	Kn: REAL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// Test postavke za reverziranje 0..100%
(*
Tgen1(IN:=NOT bTick , PT:=T#5S , Q=>bTick , ET=> );
TP1(IN:=bTick , PT:=Tgen1.PT/2 , Q=>bTakt , ET=> );
*)
Tgen1(IN:=bInDeadband , PT:=T#2S , Q=>bTick , ET=> );
R_Tgen1(CLK:=Tgen1.Q , Q=>bTick );
IF bTick THEN
	bTakt:=NOT bTakt;
END_IF

// MODIFICIRANO - postavljamo target umjesto direktnog setpointa
IF bTakt THEN
    rSetpointTarget := rSetpointTarget_Min;
ELSE
    rSetpointTarget := rSetpointTarget_Max;
END_IF

// NOVO - Rampiranje setpointa
IF rSetpoint < rSetpointTarget - 0.1 THEN
    // Rampiranje gore
    rSetpoint := rSetpoint + rRampRate * 0.01; // 0.01 = 10ms ciklus
    IF rSetpoint > rSetpointTarget THEN
        rSetpoint := rSetpointTarget;
    END_IF
ELSIF rSetpoint > rSetpointTarget + 0.1 THEN
    // Rampiranje dolje  
    rSetpoint := rSetpoint - rRampRate * 0.01;
    IF rSetpoint < rSetpointTarget THEN
        rSetpoint := rSetpointTarget;
    END_IF
END_IF


// Skaliranje 1 okretajng pot pozicije.
rPotFeedback_V:=10.0*iwPotFeedback/32767;	//napon na ulazu u EL3002
// pozicija pomaka = 81mm
rLinearPosition:=81.0*(rPotFeedback_V-cPotMin)/(cPotMax-cPotMin);
// Sigurnosni limiti + / - 
rLinearPosition_LimMin:=5.0;	// Safe limit negativan
rLinearPosition_LimMAx:=75.0;	// Safe limit pozitivan

// Sigurnosni limiti - iskljucuju Motor
IF (rLinearPosition < rLinearPosition_LimMin) OR  (rLinearPosition > rLinearPosition_LimMAx) THEN
	bMotorOn:=FALSE;
END_IF

// Radno podrucje pomaka 0..100% = MORA BITI UNUTAR SIGURNOSNIH LIMITA
rRadno_Min_Pos:=10.0;
rRadno_Max_Pos:=70.0;
rPotFeedback_Radno_Perc:= 100*(rLinearPosition-rRadno_Min_Pos)/(rRadno_Max_Pos-rRadno_Min_Pos);

// Open-loop kontrola
// Setpoint 0..100% = 0.....
// Limit za pretvorbu u integer 
// greska ako je veće od 32766 i manje od - 32766

// Kn ke multiplikator za setpoint u granicama -32000 .. 32000 / 0.100%
Kn:=320; // ako ide do napona napajanja 12V onda na 100% steka
// reset iz HMI
// bReset := FALSE;
IF bHMI_RESET THEN
	bSetVelOverPoz:=FALSE;
	bSetVelOverNeg:=FALSE;
    bReset := TRUE;
END_IF

IF NOT bError THEN
	bReset := FALSE;
END_IF


IF (rVelocitySetpoint*Kn > 32766) THEN
	bSetVelOverPoz:=TRUE;
END_IF
IF (rVelocitySetpoint*Kn < -32766) THEN
	bSetVelOverNeg:=TRUE;
END_IF
IF bSetVelOverPoz OR bSetVelOverNeg THEN
	bMotorOn:=FALSE;
ELSE
	nVelocitySetpoint:=LREAL_TO_INT(rVelocitySetpoint*Kn);
END_IF

// Dodano
// NOVO - POZICIJSKA REGULACIJA
IF bMotorOn THEN
    // Računaj grešku pozicije
    rError := rSetpoint - rPotFeedback_Radno_Perc;
    
    // Provjeri deadband
    bInDeadband := ABS(rError) <= rDeadband;
    
    IF NOT bInDeadband THEN
        // P regulator
        rVelocityCmd := rError * rKp;
        
        // Ograniči na max brzinu
        rVelocityCmd := LIMIT(-rMaxVelocity, rVelocityCmd, rMaxVelocity);
        
        // Primjeni minimalnu brzinu
        IF (ABS(rVelocityCmd) > 0.1) AND (ABS(rVelocityCmd) < rMinVelocity) THEN
            IF rVelocityCmd > 0 THEN
                rVelocityCmd := rMinVelocity;
            ELSE
                rVelocityCmd := -rMinVelocity;
            END_IF
        END_IF
    ELSE
        // Unutar deadband - zaustavi
        rVelocityCmd := 0.0;
    END_IF
    
    // Postavi brzinu
    rVelocitySetpoint := rVelocityCmd;
ELSE
    rVelocitySetpoint := 0.0;
END_IF

// Računanje brzine iz promjene pozicije

// Timer za periodičko računanje brzine
fbVelocityTimer(IN:= NOT fbVelocityTimer.Q, PT:= tSampleTime);

// Računaj brzinu kada timer istekne
IF fbVelocityTimer.Q THEN
    // Promjena pozicije u %
    rDeltaPosition := rLinearPosition - rLastPosition;
    
    // Brzina u mm/s !!!! NAVOJ IMA MULTIPLIKATOR X2
    rActualVelocity := rDeltaPosition / 0.05 / 2 ; // 50ms = 0.05s
    
    // Spremi trenutnu poziciju
    rLastPosition := rLinearPosition;
    
    // Filter brzine (PT1)
    rVelocityFiltered := rVelocityFiltered * (1.0 - rFilterConst) + 
                        rActualVelocity * rFilterConst;
END_IF

// Preračun u druge jedinice
// 81mm =  171.3 okr Motora
// RPM motora
rActualVelocityRPM := 60*171.3*rActualVelocity/81 ;


// =======================  DIVER PREMA TERMINALU

// driver prema EL7342
IF bMotorOn THEN
    bEnable := TRUE;
    bReduceTorque := FALSE;  // Puna snaga
 ELSE
    bEnable := FALSE;
    bReduceTorque := FALSE;
    nVelocitySetpoint := 0;
END_IF

(*
IF bMotorOn THEN
    nControlWord := 16#000F;
ELSE
    nControlWord := 16#0006;
    nVelocitySetpoint := 0;
END_IF
*)

rMotorVoltage:=(UINT_TO_INT(nMotorVoltage))/1000.0;
rMotorCurrent:=(UINT_TO_INT(nMotorCurrent))/1000.0;
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>