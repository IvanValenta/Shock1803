<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.17">
  <POU Name="PRG_Can" Id="{5f39a0ae-cb2a-494d-a7f5-eb8f3de5fe9f}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM PRG_CAN
VAR
    i           : INT;
    byMaskUSINT : USINT;
    byMaskUINT  : UINT;
    bInitDone   : BOOL := FALSE;
    nBox10Keys  : INT;
    nBox11Keys  : INT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[
// USINT tipka ima maksimalno 8 bitova
nBox10Keys := LIMIT(0, TO_INT(GVL_CAN.cBox10_Keys), 8);
nBox11Keys := LIMIT(0, TO_INT(GVL_CAN.cBox11_Keys), 8);

IF NOT bInitDone THEN
    FOR i := 1 TO nBox10Keys DO
        GVL_CAN.aBtn_Box10[i] := FALSE;
        GVL_CAN.aLedColorRaw_Box10[i] := TO_USINT(E_KeyLedColor.Off);
        GVL_CAN.aLedColor_Box10[i] := E_KeyLedColor.Off;
        GVL_CAN.aLedBlink_Box10[i] := FALSE;
    END_FOR;

    FOR i := 1 TO nBox11Keys DO
        GVL_CAN.aBtn_Box11[i] := FALSE;
        GVL_CAN.aLedColorRaw_Box11[i] := TO_USINT(E_KeyLedColor.Off);
        GVL_CAN.aLedColor_Box11[i] := E_KeyLedColor.Off;
        GVL_CAN.aLedBlink_Box11[i] := FALSE;
    END_FOR;

    FOR i := 1 TO GVL_CAN.cBox20_Keys DO
        GVL_CAN.aBtn_Box20[i] := FALSE;
    END_FOR;

    bInitDone := TRUE;
END_IF;


// =====================================================
// DECODE BUTTONS - BOX10
// =====================================================
FOR i := 1 TO nBox10Keys DO
    byMaskUSINT := SHL(USINT#1, i - 1);
    GVL_CAN.aBtn_Box10[i] := (GVL_CAN.diBox10_ButtonsRaw AND byMaskUSINT) <> 0;
END_FOR;


// =====================================================
// DECODE BUTTONS - BOX11
// =====================================================
FOR i := 1 TO nBox11Keys DO
    byMaskUSINT := SHL(USINT#1, i - 1);
    GVL_CAN.aBtn_Box11[i] := (GVL_CAN.diBox11_ButtonsRaw AND byMaskUSINT) <> 0;
END_FOR;


// =====================================================
// DECODE BUTTONS - BOX20
// =====================================================
FOR i := 1 TO GVL_CAN.cBox20_Keys DO
    byMaskUINT := SHL(UINT#1, i - 1);
    GVL_CAN.aBtn_Box20[i] := (GVL_CAN.diBox20_ButtonsRaw AND byMaskUINT) <> 0;
END_FOR;


// =====================================================
// LED OUTPUT BUILD - BOX10
// =====================================================
GVL_CAN.doBox10_LedStateRedRaw   := 0;
GVL_CAN.doBox10_LedStateGreenRaw := 0;
GVL_CAN.doBox10_LedStateBlueRaw  := 0;

GVL_CAN.doBox10_LedBlinkRedRaw   := 0;
GVL_CAN.doBox10_LedBlinkGreenRaw := 0;
GVL_CAN.doBox10_LedBlinkBlueRaw  := 0;

FOR i := 1 TO nBox10Keys DO
    byMaskUSINT := SHL(USINT#1, i - 1);

    // Validacija raspona (HMI/ADS -> raw USINT -> enum)
    IF GVL_CAN.aLedColorRaw_Box10[i] <= TO_USINT(E_KeyLedColor.White) THEN
        GVL_CAN.aLedColor_Box10[i] := USINT_TO_E_KeyLedColor(GVL_CAN.aLedColorRaw_Box10[i]);
    ELSE
        GVL_CAN.aLedColor_Box10[i] := E_KeyLedColor.Off;
        GVL_CAN.aLedColorRaw_Box10[i] := TO_USINT(E_KeyLedColor.Off);
    END_IF;

    CASE GVL_CAN.aLedColor_Box10[i] OF
        E_KeyLedColor.Off:
            // ništa

        E_KeyLedColor.Red:
            GVL_CAN.doBox10_LedStateRedRaw := GVL_CAN.doBox10_LedStateRedRaw OR byMaskUSINT;

        E_KeyLedColor.Green:
            GVL_CAN.doBox10_LedStateGreenRaw := GVL_CAN.doBox10_LedStateGreenRaw OR byMaskUSINT;

        E_KeyLedColor.Blue:
            GVL_CAN.doBox10_LedStateBlueRaw := GVL_CAN.doBox10_LedStateBlueRaw OR byMaskUSINT;

        E_KeyLedColor.Yellow:
            GVL_CAN.doBox10_LedStateRedRaw := GVL_CAN.doBox10_LedStateRedRaw OR byMaskUSINT;
            GVL_CAN.doBox10_LedStateGreenRaw := GVL_CAN.doBox10_LedStateGreenRaw OR byMaskUSINT;

        E_KeyLedColor.Cyan:
            GVL_CAN.doBox10_LedStateGreenRaw := GVL_CAN.doBox10_LedStateGreenRaw OR byMaskUSINT;
            GVL_CAN.doBox10_LedStateBlueRaw := GVL_CAN.doBox10_LedStateBlueRaw OR byMaskUSINT;

        E_KeyLedColor.Magenta:
            GVL_CAN.doBox10_LedStateRedRaw := GVL_CAN.doBox10_LedStateRedRaw OR byMaskUSINT;
            GVL_CAN.doBox10_LedStateBlueRaw := GVL_CAN.doBox10_LedStateBlueRaw OR byMaskUSINT;

        E_KeyLedColor.White:
            GVL_CAN.doBox10_LedStateRedRaw := GVL_CAN.doBox10_LedStateRedRaw OR byMaskUSINT;
            GVL_CAN.doBox10_LedStateGreenRaw := GVL_CAN.doBox10_LedStateGreenRaw OR byMaskUSINT;
            GVL_CAN.doBox10_LedStateBlueRaw := GVL_CAN.doBox10_LedStateBlueRaw OR byMaskUSINT;
    END_CASE;

    IF GVL_CAN.aLedBlink_Box10[i] THEN
        CASE GVL_CAN.aLedColor_Box10[i] OF
            E_KeyLedColor.Off:
                // ništa

            E_KeyLedColor.Red:
                GVL_CAN.doBox10_LedBlinkRedRaw := GVL_CAN.doBox10_LedBlinkRedRaw OR byMaskUSINT;

            E_KeyLedColor.Green:
                GVL_CAN.doBox10_LedBlinkGreenRaw := GVL_CAN.doBox10_LedBlinkGreenRaw OR byMaskUSINT;

            E_KeyLedColor.Blue:
                GVL_CAN.doBox10_LedBlinkBlueRaw := GVL_CAN.doBox10_LedBlinkBlueRaw OR byMaskUSINT;

            E_KeyLedColor.Yellow:
                GVL_CAN.doBox10_LedBlinkRedRaw := GVL_CAN.doBox10_LedBlinkRedRaw OR byMaskUSINT;
                GVL_CAN.doBox10_LedBlinkGreenRaw := GVL_CAN.doBox10_LedBlinkGreenRaw OR byMaskUSINT;

            E_KeyLedColor.Cyan:
                GVL_CAN.doBox10_LedBlinkGreenRaw := GVL_CAN.doBox10_LedBlinkGreenRaw OR byMaskUSINT;
                GVL_CAN.doBox10_LedBlinkBlueRaw := GVL_CAN.doBox10_LedBlinkBlueRaw OR byMaskUSINT;

            E_KeyLedColor.Magenta:
                GVL_CAN.doBox10_LedBlinkRedRaw := GVL_CAN.doBox10_LedBlinkRedRaw OR byMaskUSINT;
                GVL_CAN.doBox10_LedBlinkBlueRaw := GVL_CAN.doBox10_LedBlinkBlueRaw OR byMaskUSINT;

            E_KeyLedColor.White:
                GVL_CAN.doBox10_LedBlinkRedRaw := GVL_CAN.doBox10_LedBlinkRedRaw OR byMaskUSINT;
                GVL_CAN.doBox10_LedBlinkGreenRaw := GVL_CAN.doBox10_LedBlinkGreenRaw OR byMaskUSINT;
                GVL_CAN.doBox10_LedBlinkBlueRaw := GVL_CAN.doBox10_LedBlinkBlueRaw OR byMaskUSINT;
        END_CASE;
    END_IF;
END_FOR;

IF GVL_CAN.byLedBrightness_Box10 > 16#3F THEN
    GVL_CAN.doBox10_LedBrightnessRaw := 16#3F;
ELSE
    GVL_CAN.doBox10_LedBrightnessRaw := GVL_CAN.byLedBrightness_Box10;
END_IF;

IF GVL_CAN.byBacklightBrightness_Box10 > 16#3F THEN
    GVL_CAN.doBox10_BacklightBrightnessRaw := 16#3F;
ELSE
    GVL_CAN.doBox10_BacklightBrightnessRaw := GVL_CAN.byBacklightBrightness_Box10;
END_IF;

GVL_CAN.doBox10_BacklightColorRaw := TO_USINT(GVL_CAN.eBacklightColor_Box10);


// =====================================================
// LED OUTPUT BUILD - BOX11
// =====================================================
GVL_CAN.doBox11_LedStateRedRaw   := 0;
GVL_CAN.doBox11_LedStateGreenRaw := 0;
GVL_CAN.doBox11_LedStateBlueRaw  := 0;

GVL_CAN.doBox11_LedBlinkRedRaw   := 0;
GVL_CAN.doBox11_LedBlinkGreenRaw := 0;
GVL_CAN.doBox11_LedBlinkBlueRaw  := 0;

FOR i := 1 TO nBox11Keys DO
    byMaskUSINT := SHL(USINT#1, i - 1);

    // Validacija raspona (HMI/ADS -> raw USINT -> enum)
    IF GVL_CAN.aLedColorRaw_Box11[i] <= TO_USINT(E_KeyLedColor.White) THEN
        GVL_CAN.aLedColor_Box11[i] := USINT_TO_E_KeyLedColor(GVL_CAN.aLedColorRaw_Box11[i]);
    ELSE
        GVL_CAN.aLedColor_Box11[i] := E_KeyLedColor.Off;
        GVL_CAN.aLedColorRaw_Box11[i] := TO_USINT(E_KeyLedColor.Off);
    END_IF;

    CASE GVL_CAN.aLedColor_Box11[i] OF
        E_KeyLedColor.Off:
            // ništa

        E_KeyLedColor.Red:
            GVL_CAN.doBox11_LedStateRedRaw := GVL_CAN.doBox11_LedStateRedRaw OR byMaskUSINT;

        E_KeyLedColor.Green:
            GVL_CAN.doBox11_LedStateGreenRaw := GVL_CAN.doBox11_LedStateGreenRaw OR byMaskUSINT;

        E_KeyLedColor.Blue:
            GVL_CAN.doBox11_LedStateBlueRaw := GVL_CAN.doBox11_LedStateBlueRaw OR byMaskUSINT;

        E_KeyLedColor.Yellow:
            GVL_CAN.doBox11_LedStateRedRaw := GVL_CAN.doBox11_LedStateRedRaw OR byMaskUSINT;
            GVL_CAN.doBox11_LedStateGreenRaw := GVL_CAN.doBox11_LedStateGreenRaw OR byMaskUSINT;

        E_KeyLedColor.Cyan:
            GVL_CAN.doBox11_LedStateGreenRaw := GVL_CAN.doBox11_LedStateGreenRaw OR byMaskUSINT;
            GVL_CAN.doBox11_LedStateBlueRaw := GVL_CAN.doBox11_LedStateBlueRaw OR byMaskUSINT;

        E_KeyLedColor.Magenta:
            GVL_CAN.doBox11_LedStateRedRaw := GVL_CAN.doBox11_LedStateRedRaw OR byMaskUSINT;
            GVL_CAN.doBox11_LedStateBlueRaw := GVL_CAN.doBox11_LedStateBlueRaw OR byMaskUSINT;

        E_KeyLedColor.White:
            GVL_CAN.doBox11_LedStateRedRaw := GVL_CAN.doBox11_LedStateRedRaw OR byMaskUSINT;
            GVL_CAN.doBox11_LedStateGreenRaw := GVL_CAN.doBox11_LedStateGreenRaw OR byMaskUSINT;
            GVL_CAN.doBox11_LedStateBlueRaw := GVL_CAN.doBox11_LedStateBlueRaw OR byMaskUSINT;
    END_CASE;

    IF GVL_CAN.aLedBlink_Box11[i] THEN
        CASE GVL_CAN.aLedColor_Box11[i] OF
            E_KeyLedColor.Off:
                // ništa

            E_KeyLedColor.Red:
                GVL_CAN.doBox11_LedBlinkRedRaw := GVL_CAN.doBox11_LedBlinkRedRaw OR byMaskUSINT;

            E_KeyLedColor.Green:
                GVL_CAN.doBox11_LedBlinkGreenRaw := GVL_CAN.doBox11_LedBlinkGreenRaw OR byMaskUSINT;

            E_KeyLedColor.Blue:
                GVL_CAN.doBox11_LedBlinkBlueRaw := GVL_CAN.doBox11_LedBlinkBlueRaw OR byMaskUSINT;

            E_KeyLedColor.Yellow:
                GVL_CAN.doBox11_LedBlinkRedRaw := GVL_CAN.doBox11_LedBlinkRedRaw OR byMaskUSINT;
                GVL_CAN.doBox11_LedBlinkGreenRaw := GVL_CAN.doBox11_LedBlinkGreenRaw OR byMaskUSINT;

            E_KeyLedColor.Cyan:
                GVL_CAN.doBox11_LedBlinkGreenRaw := GVL_CAN.doBox11_LedBlinkGreenRaw OR byMaskUSINT;
                GVL_CAN.doBox11_LedBlinkBlueRaw := GVL_CAN.doBox11_LedBlinkBlueRaw OR byMaskUSINT;

            E_KeyLedColor.Magenta:
                GVL_CAN.doBox11_LedBlinkRedRaw := GVL_CAN.doBox11_LedBlinkRedRaw OR byMaskUSINT;
                GVL_CAN.doBox11_LedBlinkBlueRaw := GVL_CAN.doBox11_LedBlinkBlueRaw OR byMaskUSINT;

            E_KeyLedColor.White:
                GVL_CAN.doBox11_LedBlinkRedRaw := GVL_CAN.doBox11_LedBlinkRedRaw OR byMaskUSINT;
                GVL_CAN.doBox11_LedBlinkGreenRaw := GVL_CAN.doBox11_LedBlinkGreenRaw OR byMaskUSINT;
                GVL_CAN.doBox11_LedBlinkBlueRaw := GVL_CAN.doBox11_LedBlinkBlueRaw OR byMaskUSINT;
        END_CASE;
    END_IF;
END_FOR;

IF GVL_CAN.byLedBrightness_Box11 > 16#3F THEN
    GVL_CAN.doBox11_LedBrightnessRaw := 16#3F;
ELSE
    GVL_CAN.doBox11_LedBrightnessRaw := GVL_CAN.byLedBrightness_Box11;
END_IF;

IF GVL_CAN.byBacklightBrightness_Box11 > 16#3F THEN
    GVL_CAN.doBox11_BacklightBrightnessRaw := 16#3F;
ELSE
    GVL_CAN.doBox11_BacklightBrightnessRaw := GVL_CAN.byBacklightBrightness_Box11;
END_IF;

GVL_CAN.doBox11_BacklightColorRaw := TO_USINT(GVL_CAN.eBacklightColor_Box11);]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>
