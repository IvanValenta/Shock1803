<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.17">
  <POU Name="PRG_Can" Id="{5f39a0ae-cb2a-494d-a7f5-eb8f3de5fe9f}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM PRG_CAN
VAR
    i           : INT;
    byMaskUSINT : USINT;
    byMaskUINT  : UINT;
    bInitDone   : BOOL := FALSE;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[
IF NOT bInitDone THEN
    FOR i := 1 TO GVL_CAN.cBox10_Keys DO
        GVL_CAN.aBtn_Box10[i] := FALSE;
    END_FOR;

    FOR i := 1 TO GVL_CAN.cBox11_Keys DO
        GVL_CAN.aBtn_Box11[i] := FALSE;
    END_FOR;

    FOR i := 1 TO GVL_CAN.cBox20_Keys DO
        GVL_CAN.aBtn_Box20[i] := FALSE;
    END_FOR;

    bInitDone := TRUE;
END_IF;


// =====================================================
// 1) DECODE svih tipki
// =====================================================
FOR i := 1 TO GVL_CAN.cBox10_Keys DO
    byMaskUSINT := SHL(USINT#1, i - 1);
    GVL_CAN.aBtn_Box10[i] := (GVL_CAN.diBox10_ButtonsRaw AND byMaskUSINT) <> 0;
END_FOR;

FOR i := 1 TO GVL_CAN.cBox11_Keys DO
    byMaskUSINT := SHL(USINT#1, i - 1);
    GVL_CAN.aBtn_Box11[i] := (GVL_CAN.diBox11_ButtonsRaw AND byMaskUSINT) <> 0;
END_FOR;

FOR i := 1 TO GVL_CAN.cBox20_Keys DO
    byMaskUINT := SHL(UINT#1, i - 1);
    GVL_CAN.aBtn_Box20[i] := (GVL_CAN.diBox20_ButtonsRaw AND byMaskUINT) <> 0;
END_FOR;


// =====================================================
// 2) Jednostavan prikaz tipki na LED (lakše za test)
//    - pritisnuta tipka -> zelena LED
//    - puštena tipka    -> LED ugašena
// =====================================================
GVL_CAN.doBox10_LedStateRedRaw   := 0;
GVL_CAN.doBox10_LedStateGreenRaw := 0;
GVL_CAN.doBox10_LedStateBlueRaw  := 0;
GVL_CAN.doBox10_LedBlinkRedRaw   := 0;
GVL_CAN.doBox10_LedBlinkGreenRaw := 0;
GVL_CAN.doBox10_LedBlinkBlueRaw  := 0;

FOR i := 1 TO GVL_CAN.cBox10_Keys DO
    IF GVL_CAN.aBtn_Box10[i] THEN
        byMaskUSINT := SHL(USINT#1, i - 1);
        GVL_CAN.doBox10_LedStateGreenRaw := GVL_CAN.doBox10_LedStateGreenRaw OR byMaskUSINT;
    END_IF;
END_FOR;

GVL_CAN.doBox11_LedStateRedRaw   := 0;
GVL_CAN.doBox11_LedStateGreenRaw := 0;
GVL_CAN.doBox11_LedStateBlueRaw  := 0;
GVL_CAN.doBox11_LedBlinkRedRaw   := 0;
GVL_CAN.doBox11_LedBlinkGreenRaw := 0;
GVL_CAN.doBox11_LedBlinkBlueRaw  := 0;

FOR i := 1 TO GVL_CAN.cBox11_Keys DO
    IF GVL_CAN.aBtn_Box11[i] THEN
        byMaskUSINT := SHL(USINT#1, i - 1);
        GVL_CAN.doBox11_LedStateGreenRaw := GVL_CAN.doBox11_LedStateGreenRaw OR byMaskUSINT;
    END_IF;
END_FOR;


// =====================================================
// 3) Fiksna svjetlina i amber pozadina
// =====================================================
GVL_CAN.doBox10_LedBrightnessRaw       := 16#3F;
GVL_CAN.doBox10_BacklightBrightnessRaw := 16#10;
GVL_CAN.doBox10_BacklightColorRaw      := TO_USINT(E_BacklightColor.Amber);

GVL_CAN.doBox11_LedBrightnessRaw       := 16#3F;
GVL_CAN.doBox11_BacklightBrightnessRaw := 16#10;
GVL_CAN.doBox11_BacklightColorRaw      := TO_USINT(E_BacklightColor.Amber);
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>
