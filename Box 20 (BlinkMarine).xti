<?xml version="1.0"?>
<TcSmItem xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.beckhoff.com/schemas/2012/07/TcSmProject" TcSmVersion="1.0" TcVersion="3.1.4026.20" ClassName="CCanNodeDef" SubType="5003">
	<Box Id="24" BoxType="5003">
		<Name>__FILENAME__</Name>
		<ImageId>41</ImageId>
		<Vars VarGrpType="1">
			<Name>Inputs</Name>
			<Var BoxStateVariable="true">
				<Name>NodeState</Name>
				<Comment><![CDATA[Master- and Slave-Mode:
   0 = No error

Master-Mode:
   1 = Node deactivated
   2 = Node not found
   4 = SDO syntax error at StartUp
   5 = SDO data mismatch at StartUp
   8 = Node StartUp in progress
  11 = CAN-Controller is Bus-OFF
  12 = Pre-Operational
  13 = Server bus fault
  14 = Guarding: toggle error
  20 = TxPDO too short
  22 = Expected TxPDO is missing
  23 = Node is Operational but not all TxPDOs were received
  31 = only for EtherCAT gateways: WC-State of cyclic EtherCAT frame is 1
  +64 = startup of slave is finished 

Slave-Mode:
 128 = Node is Operational but not all RxPDOs were received
 129 = Node is Pre-Operational
 130 = Node is Stopped
]]></Comment>
				<Type>USINT</Type>
				<BitOffs>48</BitOffs>
			</Var>
			<Var BoxStateVariable="true">
				<Name>DiagFlag</Name>
				<Comment><![CDATA[0 = Diagnosis Data unchanged
1 = Diagnosis Data changed, use ADS-Read to get the data]]></Comment>
				<Type>BIT</Type>
				<BitOffs>99</BitOffs>
			</Var>
		</Vars>
		<Vars VarGrpType="2">
			<Name>Outputs</Name>
		</Vars>
		<CanOpen NodeId="20" BaudSupport="511" FixedSdos="10" GenerateFixedSdos="true" DvFlag_Active="true" AddTypeInfo="11" DevProfNum="401" CobIDEmcy="148" CobIDGuard="1812" GuardTime="100" LifeTime="3" VendorId="994" SdoTimeout="0">
			<Sdo Index="6144" SubIndex="1" Length="4" Value="404"/>
			<Sdo Index="6144" SubIndex="2" Length="1" Value="254"/>
