  <div id="LedP3_Red"    data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="8" data-tchmi-top="204" data-tchmi-width="16" data-tchmi-height="16" data-tchmi-fill-color='{"colorHex":"#FF1744"}' data-tchmi-opacity="%s%ADS.PLC1.GVL_HMI.bLed_P3_Red%/s%"></div>
  <div id="LblP3" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextblock" data-tchmi-left="28" data-tchmi-top="204" data-tchmi-width="20" data-tchmi-height="16" data-tchmi-text="P3" data-tchmi-font-size="12" data-tchmi-font-size-unit="px" data-tchmi-foreground-color='{"colorHex":"#E0E0E0"}'></div>
