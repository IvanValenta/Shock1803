<div id="Desktop" data-tchmi-type="TcHmi.Controls.System.TcHmiView" data-tchmi-top="0" data-tchmi-left="0" data-tchmi-width-mode="Content" data-tchmi-min-width="100" data-tchmi-min-width-unit="%" data-tchmi-height-mode="Content" data-tchmi-min-height="100" data-tchmi-min-height-unit="%" data-tchmi-creator-viewport-height="480" data-tchmi-background-color='{"colorHex":"#0F0F1A"}'>

  <!-- ====================================================== -->
  <!-- HEADER: Engine status + Alarms (y=0, h=44)            -->
  <!-- ====================================================== -->
  <div id="BgHeader" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiRectangle" data-tchmi-left="0" data-tchmi-top="0" data-tchmi-width="800" data-tchmi-height="44" data-tchmi-fill-color='{"colorHex":"#0A0A14"}'></div>

  <div id="LblMotor" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextblock" data-tchmi-left="6" data-tchmi-top="4" data-tchmi-width="50" data-tchmi-height="14" data-tchmi-text="MOTOR" data-tchmi-font-size="10" data-tchmi-font-size-unit="px" data-tchmi-font-weight="Bold" data-tchmi-foreground-color='{"colorHex":"#888888"}'></div>
  <div id="LblRpm" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextblock" data-tchmi-left="6" data-tchmi-top="22" data-tchmi-width="35" data-tchmi-height="14" data-tchmi-text="RPM:" data-tchmi-font-size="10" data-tchmi-font-size-unit="px" data-tchmi-foreground-color='{"colorHex":"#666666"}'></div>
  <div id="TxtRpm" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextblock" data-tchmi-left="42" data-tchmi-top="20" data-tchmi-width="65" data-tchmi-height="18" data-tchmi-font-size="14" data-tchmi-font-size-unit="px" data-tchmi-font-weight="Bold" data-tchmi-foreground-color='{"colorHex":"#00E5FF"}' data-tchmi-text="%s%ADS.PLC1.GVL_IO.fEngineRPM_Scaled%/s%"></div>

  <!-- Engine LED: base grey + green overlay -->
  <div id="LedRunning"       data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="115" data-tchmi-top="6" data-tchmi-width="16" data-tchmi-height="16" data-tchmi-fill-color='{"colorHex":"#222222"}'></div>
  <div id="LedRunning_Green" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="115" data-tchmi-top="6" data-tchmi-width="16" data-tchmi-height="16" data-tchmi-fill-color='{"colorHex":"#00C853"}' data-tchmi-opacity="%s%ADS.PLC1.GVL_HMI.bLed_Engine_Green%/s%"></div>

  <div id="LblGear" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextblock" data-tchmi-left="115" data-tchmi-top="24" data-tchmi-width="35" data-tchmi-height="14" data-tchmi-text="GEAR:" data-tchmi-font-size="10" data-tchmi-font-size-unit="px" data-tchmi-foreground-color='{"colorHex":"#666666"}'></div>
  <div id="TxtGear" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextblock" data-tchmi-left="152" data-tchmi-top="22" data-tchmi-width="55" data-tchmi-height="16" data-tchmi-font-size="12" data-tchmi-font-size-unit="px" data-tchmi-foreground-color='{"colorHex":"#FFD600"}' data-tchmi-text="%s%ADS.PLC1.GVL_ENGINE.eGearOut%/s%"></div>

  <!-- Alarm: High RPM -->
  <div id="LedAlarmRpm"    data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="218" data-tchmi-top="10" data-tchmi-width="10" data-tchmi-height="10" data-tchmi-fill-color='{"colorHex":"#2A2A2A"}'></div>
  <div id="LedAlarmRpm_On" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="218" data-tchmi-top="10" data-tchmi-width="10" data-tchmi-height="10" data-tchmi-fill-color='{"colorHex":"#FF1744"}' data-tchmi-opacity="%s%ADS.PLC1.GVL_ENGINE.bAlarm_HighRPM%/s%"></div>
  <div id="LblAlarmRpm" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextblock" data-tchmi-left="232" data-tchmi-top="6" data-tchmi-width="55" data-tchmi-height="14" data-tchmi-text="HI RPM" data-tchmi-font-size="9" data-tchmi-font-size-unit="px" data-tchmi-foreground-color='{"colorHex":"#888888"}'></div>

  <!-- Alarm: Door FWD -->
  <div id="LedAlarmFwd"    data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="218" data-tchmi-top="26" data-tchmi-width="10" data-tchmi-height="10" data-tchmi-fill-color='{"colorHex":"#2A2A2A"}'></div>
  <div id="LedAlarmFwd_On" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="218" data-tchmi-top="26" data-tchmi-width="10" data-tchmi-height="10" data-tchmi-fill-color='{"colorHex":"#FF1744"}' data-tchmi-opacity="%s%ADS.PLC1.GVL_HMI.bAlarm_DoorFwd%/s%"></div>
  <div id="LblAlarmFwd" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextblock" data-tchmi-left="232" data-tchmi-top="22" data-tchmi-width="55" data-tchmi-height="14" data-tchmi-text="V.FWD" data-tchmi-font-size="9" data-tchmi-font-size-unit="px" data-tchmi-foreground-color='{"colorHex":"#888888"}'></div>

  <!-- Alarm: Door AFT -->
  <div id="LedAlarmAft"    data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="290" data-tchmi-top="10" data-tchmi-width="10" data-tchmi-height="10" data-tchmi-fill-color='{"colorHex":"#2A2A2A"}'></div>
  <div id="LedAlarmAft_On" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="290" data-tchmi-top="10" data-tchmi-width="10" data-tchmi-height="10" data-tchmi-fill-color='{"colorHex":"#FF1744"}' data-tchmi-opacity="%s%ADS.PLC1.GVL_HMI.bAlarm_DoorAft%/s%"></div>
  <div id="LblAlarmAft" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextblock" data-tchmi-left="304" data-tchmi-top="6" data-tchmi-width="55" data-tchmi-height="14" data-tchmi-text="V.AFT" data-tchmi-font-size="9" data-tchmi-font-size-unit="px" data-tchmi-foreground-color='{"colorHex":"#888888"}'></div>

  <!-- Alarm box (top right) -->
  <div id="BgAlarm"    data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiRectangle" data-tchmi-left="700" data-tchmi-top="4" data-tchmi-width="92" data-tchmi-height="36" data-tchmi-fill-color='{"colorHex":"#1A1A2E"}'></div>
  <div id="BgAlarm_On" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiRectangle" data-tchmi-left="700" data-tchmi-top="4" data-tchmi-width="92" data-tchmi-height="36" data-tchmi-fill-color='{"colorHex":"#FF1744"}' data-tchmi-opacity="%s%ADS.PLC1.GVL_Alarms.bAnyAlarmActive%/s%"></div>
  <div id="TxtAlarm" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextblock" data-tchmi-left="700" data-tchmi-top="4" data-tchmi-width="92" data-tchmi-height="36" data-tchmi-text="! ALARM" data-tchmi-font-size="13" data-tchmi-font-size-unit="px" data-tchmi-font-weight="Bold" data-tchmi-text-horizontal-alignment="Center" data-tchmi-text-vertical-alignment="Center" data-tchmi-foreground-color='{"colorHex":"#FFFFFF"}'></div>

  <div id="DivHeader" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiRectangle" data-tchmi-left="0" data-tchmi-top="44" data-tchmi-width="800" data-tchmi-height="1" data-tchmi-fill-color='{"colorHex":"#2D2D50"}'></div>

  <!-- ====================================================== -->
  <!-- PORT PANEL (x=0, y=45, w=185, h=380)                  -->
  <!-- ====================================================== -->
  <div id="BgPort" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiRectangle" data-tchmi-left="0" data-tchmi-top="45" data-tchmi-width="185" data-tchmi-height="380" data-tchmi-fill-color='{"colorHex":"#12122A"}'></div>
  <div id="TitlePort" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextblock" data-tchmi-left="0" data-tchmi-top="48" data-tchmi-width="185" data-tchmi-height="20" data-tchmi-text="PORT" data-tchmi-font-size="13" data-tchmi-font-size-unit="px" data-tchmi-font-weight="Bold" data-tchmi-text-horizontal-alignment="Center" data-tchmi-foreground-color='{"colorHex":"#AAAACC"}'></div>

  <!-- P1 -->
  <div id="LedP1"        data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="8" data-tchmi-top="76" data-tchmi-width="16" data-tchmi-height="16" data-tchmi-fill-color='{"colorHex":"#2A2A44"}'></div>
  <div id="LedP1_Cyan"   data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="8" data-tchmi-top="76" data-tchmi-width="16" data-tchmi-height="16" data-tchmi-fill-color='{"colorHex":"#00E5FF"}' data-tchmi-opacity="%s%ADS.PLC1.GVL_HMI.bLed_P1_Cyan%/s%"></div>
  <div id="LedP1_Yellow" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="8" data-tchmi-top="76" data-tchmi-width="16" data-tchmi-height="16" data-tchmi-fill-color='{"colorHex":"#FFD600"}' data-tchmi-opacity="%s%ADS.PLC1.GVL_HMI.bLed_P1_Yellow%/s%"></div>
  <div id="LedP1_Red"    data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="8" data-tchmi-top="76" data-tchmi-width="16" data-tchmi-height="16" data-tchmi-fill-color='{"colorHex":"#FF1744"}' data-tchmi-opacity="%s%ADS.PLC1.GVL_HMI.bLed_P1_Red%/s%"></div>
  <div id="LblP1" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextblock" data-tchmi-left="28" data-tchmi-top="76" data-tchmi-width="20" data-tchmi-height="16" data-tchmi-text="P1" data-tchmi-font-size="12" data-tchmi-font-size-unit="px" data-tchmi-foreground-color='{"colorHex":"#E0E0E0"}'></div>
  <div id="GaugeP1" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiProgressBar" data-tchmi-left="50" data-tchmi-top="78" data-tchmi-width="90" data-tchmi-height="12" data-tchmi-min-value="0" data-tchmi-max-value="100" data-tchmi-bar-color='{"colorHex":"#00E5FF"}' data-tchmi-background-color='{"colorHex":"#1A1A3A"}' data-tchmi-value="%s%ADS.PLC1.GVL_IO.fLevel_Bal_P1_Pct_Hmi%/s%"></div>
  <div id="TxtP1Pct" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextblock" data-tchmi-left="144" data-tchmi-top="76" data-tchmi-width="28" data-tchmi-height="16" data-tchmi-font-size="10" data-tchmi-font-size-unit="px" data-tchmi-foreground-color='{"colorHex":"#888888"}' data-tchmi-text="%s%ADS.PLC1.GVL_IO.fLevel_Bal_P1_Pct_Hmi%/s%"></div>
  <div id="LedAlP1"    data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="174" data-tchmi-top="80" data-tchmi-width="8" data-tchmi-height="8" data-tchmi-fill-color='{"colorHex":"#222233"}'></div>
  <div id="LedAlP1_On" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="174" data-tchmi-top="80" data-tchmi-width="8" data-tchmi-height="8" data-tchmi-fill-color='{"colorHex":"#FF1744"}' data-tchmi-opacity="%s%ADS.PLC1.GVL_HMI.bAlarm_P1%/s%"></div>
  <div id="BtnOpenP1"  data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiButton" data-tchmi-left="8" data-tchmi-top="100" data-tchmi-width="80" data-tchmi-height="24" data-tchmi-text="OTVORI" data-tchmi-font-size="10" data-tchmi-font-size-unit="px" data-tchmi-background-color='{"colorHex":"#0A2A4A"}' data-tchmi-on-pressed='[{"id":"w","fnName":"TcHmi.Functions.Beckhoff.TcHmiServer.writeSymbol","parameter":[{"symbolExpression":"ADS.PLC1.GVL_HMI.bCmdOpen_P1"},{"value":true}]}]'></div>
  <div id="BtnCloseP1" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiButton" data-tchmi-left="96" data-tchmi-top="100" data-tchmi-width="80" data-tchmi-height="24" data-tchmi-text="ZATVORI" data-tchmi-font-size="10" data-tchmi-font-size-unit="px" data-tchmi-background-color='{"colorHex":"#2A0A0A"}' data-tchmi-on-pressed='[{"id":"w","fnName":"TcHmi.Functions.Beckhoff.TcHmiServer.writeSymbol","parameter":[{"symbolExpression":"ADS.PLC1.GVL_HMI.bCmdOpen_P1"},{"value":false}]}]'></div>

  <!-- P2 -->
  <div id="LedP2"        data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="8" data-tchmi-top="140" data-tchmi-width="16" data-tchmi-height="16" data-tchmi-fill-color='{"colorHex":"#2A2A44"}'></div>
  <div id="LedP2_Cyan"   data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="8" data-tchmi-top="140" data-tchmi-width="16" data-tchmi-height="16" data-tchmi-fill-color='{"colorHex":"#00E5FF"}' data-tchmi-opacity="%s%ADS.PLC1.GVL_HMI.bLed_P2_Cyan%/s%"></div>
  <div id="LedP2_Yellow" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="8" data-tchmi-top="140" data-tchmi-width="16" data-tchmi-height="16" data-tchmi-fill-color='{"colorHex":"#FFD600"}' data-tchmi-opacity="%s%ADS.PLC1.GVL_HMI.bLed_P2_Yellow%/s%"></div>
