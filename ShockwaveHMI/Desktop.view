  <div id="LedAlP2"    data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="174" data-tchmi-top="144" data-tchmi-width="8" data-tchmi-height="8" data-tchmi-fill-color='{"colorHex":"#222233"}'></div>
  <div id="LedAlP2_On" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="174" data-tchmi-top="144" data-tchmi-width="8" data-tchmi-height="8" data-tchmi-fill-color='{"colorHex":"#FF1744"}' data-tchmi-opacity="%s%ADS.PLC1.GVL_HMI.bAlarm_P2%/s%"></div>
  <div id="BtnOpenP2"  data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiButton" data-tchmi-left="8" data-tchmi-top="164" data-tchmi-width="80" data-tchmi-height="24" data-tchmi-text="OTVORI" data-tchmi-font-size="10" data-tchmi-font-size-unit="px" data-tchmi-background-color='{"colorHex":"#0A2A4A"}' data-tchmi-on-pressed='[{"id":"w","fnName":"TcHmi.Functions.Beckhoff.TcHmiServer.writeSymbol","parameter":[{"symbolExpression":"ADS.PLC1.GVL_HMI.bCmdOpen_P2"},{"value":true}]}]'></div>
  <div id="BtnCloseP2" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiButton" data-tchmi-left="96" data-tchmi-top="164" data-tchmi-width="80" data-tchmi-height="24" data-tchmi-text="ZATVORI" data-tchmi-font-size="10" data-tchmi-font-size-unit="px" data-tchmi-background-color='{"colorHex":"#2A0A0A"}' data-tchmi-on-pressed='[{"id":"w","fnName":"TcHmi.Functions.Beckhoff.TcHmiServer.writeSymbol","parameter":[{"symbolExpression":"ADS.PLC1.GVL_HMI.bCmdOpen_P2"},{"value":false}]}]'></div>

  <!-- P3 -->
  <div id="LedP3"        data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="8" data-tchmi-top="204" data-tchmi-width="16" data-tchmi-height="16" data-tchmi-fill-color='{"colorHex":"#2A2A44"}'></div>
