  <div id="LedAlP3"    data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiEllipse" data-tchmi-left="174" data-tchmi-top="208" data-tchmi-width="8" data-tchmi-height="8" data-tchmi-fill-color='{"colorHex":"#222233"}'></div>
