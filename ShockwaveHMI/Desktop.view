  <div id="LblP2" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextblock" data-tchmi-left="28" data-tchmi-top="140" data-tchmi-width="20" data-tchmi-height="16" data-tchmi-text="P2" data-tchmi-font-size="12" data-tchmi-font-size-unit="px" data-tchmi-foreground-color='{"colorHex":"#E0E0E0"}'></div>
